<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cretyz - Login</title>
    <!-- 3D 엔진은 나중을 위해 미리 탑재 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body, html { width: 100%; height: 100%; overflow: hidden; font-family: 'Arial', sans-serif; background: #111; color: #fff; }
        
        /* 1. 로그인 화면 스타일 */
        #loginScreen {
            position: absolute; width: 100%; height: 100%;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            background: linear-gradient(135deg, #1e1e2f, #11111e); z-index: 10;
        }
        .login-box {
            background: rgba(255, 255, 255, 0.05); padding: 40px; border-radius: 12px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37); border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center; width: 90%; max-width: 400px;
        }
        h1 { margin-bottom: 24px; font-size: 2.5rem; color: #00ffcc; text-shadow: 0 0 10px rgba(0,255,204,0.3); }
        input {
            width: 100%; padding: 12px; margin-bottom: 20px; border: none; border-radius: 6px;
            background: rgba(255, 255, 255, 0.1); color: #fff; font-size: 1rem; text-align: center;
        }
        input:focus { outline: 2px solid #00ffcc; }
        button {
            width: 100%; padding: 12px; border: none; border-radius: 6px;
            background: #00ffcc; color: #111; font-size: 1rem; font-weight: bold; cursor: pointer;
            transition: all 0.2s;
        }
        button:hover { background: #00cca4; transform: scale(1.02); }

        /* 2. 게임 화면 스타일 (처음에는 숨김) */
        #gameScreen { position: absolute; width: 100%; height: 100%; display: none; }
        #gameCanvas { width: 100%; height: 100%; display: block; }
        #uiOverlay { position: absolute; top: 20px; left: 20px; font-size: 1.2rem; color: #00ffcc; }
    </style>
</head>
<body>

    <!-- [화면 1] 로그인 스크린 -->
    <div id="loginScreen">
        <div class="login-box">
            <h1>CRETYZ</h1>
            <input type="text" id="usernameInput" placeholder="닉네임을 입력하세요" maxlength="10">
            <button id="loginBtn">게임 입장</button>
        </div>
    </div>

    <!-- [화면 2] 게임 스크린 (로그인 성공 전엔 안 보임) -->
    <div id="gameScreen">
        <div id="uiOverlay">플레이어: <span id="playerTagName">-</span></div>
        <canvas id="gameCanvas"></canvas>
    </div>

    <script>
        // 여기다가 로그인 작동 및 게임 로직 스크립트를 하나씩 채워 넣을 겁니다!
    </script>
</body>
</html>

<style>
    #loginScreen {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        background: linear-gradient(135deg, #1e1e2f, #11111e); z-index: 99999;
    }
    .login-box {
        background: rgba(255, 255, 255, 0.05); padding: 40px; border-radius: 12px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37); border: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center; width: 90%; max-width: 400px; color: white; font-family: sans-serif;
    }
    .login-box h1 { margin-bottom: 24px; font-size: 2.5rem; color: #00ffcc; }
    .login-box input {
        width: 100%; padding: 12px; margin-bottom: 20px; border: none; border-radius: 6px;
        background: rgba(255, 255, 255, 0.1); color: #fff; font-size: 1rem; text-align: center;
    }
    .login-box button {
        width: 100%; padding: 12px; border: none; border-radius: 6px;
        background: #00ffcc; color: #111; font-size: 1rem; font-weight: bold; cursor: pointer;
    }
</style>

<div id="loginScreen">
    <div class="login-box">
        <h1 id="mainTitle">CRETYZ</h1>
        <div style="display: flex; margin-bottom: 20px; border-bottom: 2px solid rgba(255,255,255,0.1);">
            <div id="goLogin" style="flex: 1; padding: 10px; cursor: pointer; color: #00ffcc; font-weight: bold;">로그인</div>
            <div id="goRegister" style="flex: 1; padding: 10px; cursor: pointer; color: #aaa;">회원가입</div>
        </div>
        <input type="text" id="myId" placeholder="아이디를 입력하세요">
        <input type="password" id="myPw" placeholder="비밀번호를 입력하세요">
        <div id="msg" style="color: #ff4444; font-size: 0.9rem; margin-bottom: 15px; min-height: 20px;"></div>
        <button id="mainBtn">로그인</button>
    </div>
</div>

<script>
    const goLogin = document.getElementById('goLogin');
    const goRegister = document.getElementById('goRegister');
    const myId = document.getElementById('myId');
    const myPw = document.getElementById('myPw');
    const mainBtn = document.getElementById('mainBtn');
    const msg = document.getElementById('msg');
    const loginScreen = document.getElementById('loginScreen');
    const mainTitle = document.getElementById('mainTitle');

    // 브라우저 타이틀도 자동 변경
    document.title = "Cretyz - Login";
    mainTitle.innerText = "CRETYZ";

    let mode = 'login';

    goLogin.addEventListener('click', () => {
        mode = 'login';
        goLogin.style.color = '#00ffcc'; goRegister.style.color = '#aaa';
        mainBtn.innerText = '로그인'; msg.innerText = '';
    });

    goRegister.addEventListener('click', () => {
        mode = 'register';
        goRegister.style.color = '#00ffcc'; goLogin.style.color = '#aaa';
        mainBtn.innerText = '회원가입 완료'; msg.innerText = '';
    });

    mainBtn.addEventListener('click', () => {
        const id = myId.value.trim();
        const pw = myPw.value.trim();

        if (!id || !pw) {
            msg.innerText = '모두 입력해주세요!';
            return;
        }

        if (mode === 'register') {
            if (localStorage.getItem('game_user_' + id)) {
                msg.innerText = '이미 존재하는 아이디입니다.';
            } else {
                localStorage.setItem('game_user_' + id, pw);
                msg.style.color = '#00ffcc';
                msg.innerText = '가입 완료! 로그인 탭으로 이동합니다.';
                goLogin.click();
            }
        } else {
            if (localStorage.getItem('game_user_' + id) === pw) {
                loginScreen.style.display = 'none'; // 로그인 창 파괴! 원래 게임 등장!
                document.title = "Cretyz Brawl";
                alert(id + '님 환영합니다!');
            } else {
                msg.style.color = '#ff4444';
                msg.innerText = '아이디 또는 비밀번호가 틀렸습니다.';
            }
        }
    });
</script>
    // -----------------------------------------------------------------
    // [로그인 후 게임 화면 강제 전환 및 리사이즈 초기화]
    // -----------------------------------------------------------------
    function initGameScreen() {
        const gameCanvas = document.getElementById('gameCanvas');
        if (gameCanvas) {
            // 1. 게임 캔버스 크기를 현재 브라우저 화면에 꽉 맞추기
            gameCanvas.width = window.innerWidth;
            gameCanvas.height = window.innerHeight;
            
            // 2. 혹시 기존 게임에 resize 이벤트가 있다면 강제로 발생시켜주기
            window.dispatchEvent(new Event('resize'));
            
            console.log("게임 화면 전환 및 캔버스 초기화 완료!");
        }
    }

    // 위에 작성했던 로그인 성공 로직에 이 함수를 강제로 끼워넣기 위해 이벤트 추가
    mainBtn.addEventListener('click', () => {
        const id = myId.value.trim();
        const pw = myPw.value.trim();
        
        if (id && pw && localStorage.getItem('game_user_' + id) === pw) {
            // 로그인 성공 시점에 게임 화면을 깨우는 함수 실행!
            setTimeout(initGameScreen, 50); 
        }
    });
